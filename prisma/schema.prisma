generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ModelFileStatus {
  UPLOADING
  QUEUED
  PROCESSING
  READY
  ERROR
}

enum PrintTechnology {
  FDM
  SLA
  SLS
  MJF
  DLP
  POLYJET
}

enum Currency {
  USD
  EUR
  GBP
  NGN
  CAD
  AUD
}

enum Language {
  EN
  FR
  DE
  ES
  PT
  RU
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String
  projects       Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ---------------------------------------------------------------------------
// Project
// ---------------------------------------------------------------------------

model Project {
  id            String  @id @default(cuid())
  userId        String
  name          String
  clientName    String?
  clientContact String?
  notes         String? @db.Text

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelFile  ModelFile?
  parameters ProjectParameters?
  calculation ProjectCalculation?
  aiContent  ProjectAiContent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("projects")
}

// ---------------------------------------------------------------------------
// ModelFile
// ---------------------------------------------------------------------------

model ModelFile {
  id               String          @id @default(cuid())
  projectId        String          @unique
  originalFileName String
  storagePath      String
  format           String
  status           ModelFileStatus @default(UPLOADING)
  errorMessage     String?         @db.Text

  dimX         Decimal? @db.Decimal(12, 4)
  dimY         Decimal? @db.Decimal(12, 4)
  dimZ         Decimal? @db.Decimal(12, 4)
  volume       Decimal? @db.Decimal(18, 6)
  polygonCount Int?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("model_files")
}

// ---------------------------------------------------------------------------
// ProjectParameters
// ---------------------------------------------------------------------------

model ProjectParameters {
  id        String @id @default(cuid())
  projectId String @unique

  technology         PrintTechnology @default(FDM)
  material           String
  density            Decimal         @db.Decimal(10, 4)
  materialPrice      Decimal         @db.Decimal(14, 4)
  infillPercent      Decimal         @db.Decimal(5, 2)
  supportPercent     Decimal         @db.Decimal(5, 2)
  printingTime       Decimal         @db.Decimal(12, 4)
  postProcessingTime Decimal         @db.Decimal(12, 4)
  simulationTime     Decimal         @db.Decimal(12, 4)
  partsCount         Int             @default(1)
  batchMode          Boolean         @default(false)
  markupCoefficient  Decimal         @db.Decimal(10, 4)
  defectProbability  Decimal         @db.Decimal(6, 4)
  taxRate            Decimal         @db.Decimal(6, 4)
  depreciationRate   Decimal         @db.Decimal(10, 4)
  electricityRate    Decimal         @db.Decimal(14, 4)
  currency           Currency        @default(USD)
  language           Language        @default(EN)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_parameters")
}

// ---------------------------------------------------------------------------
// ProjectCalculation
// ---------------------------------------------------------------------------

model ProjectCalculation {
  id        String @id @default(cuid())
  projectId String @unique

  weight             Decimal @db.Decimal(14, 4)
  materialCost       Decimal @db.Decimal(16, 4)
  productionTime     Decimal @db.Decimal(14, 4)
  electricityCost    Decimal @db.Decimal(16, 4)
  depreciationCost   Decimal @db.Decimal(16, 4)
  preparationCost    Decimal @db.Decimal(16, 4)
  defectCost         Decimal @db.Decimal(16, 4)
  profit             Decimal @db.Decimal(16, 4)
  tax                Decimal @db.Decimal(16, 4)
  finalPricePerPiece Decimal @db.Decimal(16, 4)
  finalPriceBatch    Decimal @db.Decimal(16, 4)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_calculations")
}

// ---------------------------------------------------------------------------
// ProjectAiContent
// ---------------------------------------------------------------------------

model ProjectAiContent {
  id              String  @id @default(cuid())
  projectId       String  @unique
  descriptionText String? @db.Text
  commercialText  String? @db.Text

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_ai_content")
}

